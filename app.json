{
  "expo": {
    "name": "Noor Islam",
    "slug": "noor_islam",
    "version": "1.0.0",
    "owner": "youngmea1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#FAFAFA",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.noorislam.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to calculate the Qibla direction and prayer times.",
        "NSUserNotificationsUsageDescription": "We send motivational Islamic reminders to brighten your day.",
        "ExpoLocalization_supportsRTL": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B6B4B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.noorislam.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "NOTIFICATIONS",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-splash-screen",
      "expo-localization",
      "expo-status-bar",
      "expo-location",
      "expo-notifications",
      "expo-audio"
    ],
    "extra": {
      "supportsRTL": true,
      "eas": {
        "projectId": "5326e0af-9ba8-47b2-90a7-fddca64434c3"
      }
    }
  }
}
